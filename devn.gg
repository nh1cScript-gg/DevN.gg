local SafariTab = Window:CreateTab("Safari", nil)

SafariTab:CreateSection("Hunt Target")

SafariTab:CreateTextInput({
    Name        = "Unit to Hunt",
    Placeholder = "e.g. Yamato, Mahoraga, Aizen...",
    Default     = "",
    Callback    = function(text)
        safariTargetUnit = text
        if text ~= "" then
            DevNgg:Notify({ Title = "Target Set", Content = text, Duration = 2 })
        end
    end,
})

SafariTab:CreateButton({
    Name     = "Scan Safari Now",
    Callback = function()
        if safariTargetUnit == "" and not autoSafariSparking then
            DevNgg:Notify({ Title = "No Target", Content = "Set a unit name or enable sparking!", Duration = 3 })
            return
        end
        local hrp, foundName, foundReason = findSafariWithUnit(safariTargetUnit, autoSafariSparking)
        if hrp then
            local label = foundReason == "sparking" and "Sparking: " .. foundName or "Found: " .. foundName
            DevNgg:Notify({ Title = label, Content = "Teleporting to Safari NPC!", Duration = 3 })
            local myHrp = getHumanoidRootPart()
            if myHrp then
                myHrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 5, 3))
            end
        else
            DevNgg:Notify({ Title = "Not Found", Content = "Nothing found in any Safari on this server.", Duration = 3 })
        end
    end,
})

SafariTab:CreateButton({
    Name     = "List All Safari Units",
    Callback = function()
        local campaign = workspace:FindFirstChild("Campaign")
        if not campaign then
            DevNgg:Notify({ Title = "Error", Content = "Campaign not found!", Duration = 3 })
            return
        end
        local seen = {}
        print("=== CURRENT SAFARI PETS ===")
        for _, safari in ipairs(campaign:GetChildren()) do
            if safari.Name == "Safari" then
                local pets = safari:FindFirstChild("Pets")
                if pets then
                    for _, pet in ipairs(pets:GetChildren()) do
                        if not seen[pet.Name] then
                            seen[pet.Name] = true
                            print(" -", pet.Name)
                        end
                    end
                end
            end
        end
        local count = 0
        for _ in pairs(seen) do count += 1 end
        DevNgg:Notify({ Title = "Safari Units Found: " .. count, Content = "Check console (F9)!", Duration = 4 })
    end,
})

SafariTab:CreateSection("Automation")

SafariTab:CreateToggle({
