})

local SettingsTab = Window:CreateTab("Settings", nil)

SettingsTab:CreateSection("Config Management")

local currentConfigName = ""
local configDropdown    = nil

SettingsTab:CreateTextInput({
    Name        = "Config Name",
    Placeholder = "e.g. MyFarmSetup",
    Default     = "",
    Callback    = function(value) currentConfigName = value end,
})

SettingsTab:CreateButton({
    Name     = "Save Config",
    Callback = function()
        if currentConfigName == "" then
            DevNgg:Notify({ Title = "No Name", Content = "Type a config name first!", Duration = 3 })
            return
        end
        pcall(function()
            if not isfolder("AniPixels") then makefolder("AniPixels") end
            if not isfolder("AniPixels/Configs") then makefolder("AniPixels/Configs") end
            writefile("AniPixels/Configs/" .. currentConfigName .. ".json", HttpService:JSONEncode({
                -- Dragon Ball
                AutoCollect   = dragonBallAutoCollect,
                AutoHop       = dragonBallAutoHop,
                AutoWish      = dragonBallAutoWish,
                WishTargets   = wishTargets,
                -- Safari
                SafariTarget   = safariTargetUnit,
                SafariHop      = autoSafariServerHop,
                SafariSparking = autoSafariSparking,
                AutoSafari     = autoSafariEnabled,
                -- Campaign
                CampaignUnits    = autoCampaignTargetUnits,
                CampaignSparking = autoCampaignFindSparking,
                CampaignHop      = autoCampaignServerHop,
                AutoCampaign     = autoCampaignEnabled,
                -- Merge
                MergeTarget   = mergeTargetUnit,
            }))
        end)
        if configDropdown then configDropdown:SetOptions(getSavedConfigs()) end
        DevNgg:Notify({ Title = "Config Saved", Content = currentConfigName .. " saved!", Duration = 3 })
    end,
})

configDropdown = SettingsTab:CreateDropdown({
    Name     = "Load Config",
    Options  = getSavedConfigs(),
    Default  = "",
    Callback = function(selectedName)
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile("AniPixels/Configs/" .. selectedName .. ".json"))
        end)
        if not ok or not data then
            DevNgg:Notify({ Title = "Load Failed", Content = "Could not load: " .. selectedName, Duration = 3 })
            return
        end

        -- Stop all active loops first
        dragonBallAutoCollect = false
        dragonBallAutoHop     = false
        dragonBallAutoWish    = false
        autoSafariEnabled     = false
        autoCampaignEnabled   = false
        if collectLoopThread then task.cancel(collectLoopThread) collectLoopThread = nil end
        if safariThread then task.cancel(safariThread) safariThread = nil end
        if autoCampaignThread then task.cancel(autoCampaignThread) autoCampaignThread = nil end

        -- Apply Dragon Ball settings
        wishTargets = (type(data.WishTargets) == "table") and data.WishTargets or {}
        refreshWishDropdown()

        -- Apply Safari settings
        safariTargetUnit    = data.SafariTarget or ""
        autoSafariServerHop = data.SafariHop ~= false
        autoSafariSparking  = data.SafarySparking ~= false

        -- Apply Campaign settings
        if type(data.CampaignUnits) == "table" then
            autoCampaignTargetUnits = data.CampaignUnits
        end
        autoCampaignFindSparking = data.CampaignSparking ~= false
        autoCampaignServerHop    = data.CampaignHop ~= false
        mergeTargetUnit          = data.MergeTarget or ""

        -- Apply toggles (these will trigger callbacks and start loops)
        pcall(function() Window:SetToggle("AutoCollect", data.AutoCollect or false) end)
        pcall(function() Window:SetToggle("AutoHop",     data.AutoHop     or false) end)
        pcall(function() Window:SetToggle("AutoWish",    data.AutoWish    or false) end)
        pcall(function() Window:SetToggle("AutoSafari",  data.AutoSafari  or false) end)
        pcall(function() Window:SetToggle("AutoCampaignEnabled", data.AutoCampaign or false) end)

        -- Refresh campaign list dropdown
        refreshCampaignDropdown()

        -- Save which config was last selected for auto-load on next execution
        pcall(function()
            if not isfolder("AniPixels") then makefolder("AniPixels") end
            writefile("AniPixels/LastConfig.json", HttpService:JSONEncode({ lastConfig = selectedName }))
        end)

        DevNgg:Notify({ Title = "Config Loaded", Content = selectedName .. " applied!", Duration = 3 })
    end,
})

SettingsTab:CreateButton({
    Name     = "Delete Config",
    Callback = function()
        local selected = configDropdown:GetSelected()
        if not selected or selected == "" then
            DevNgg:Notify({ Title = " None Selected", Content = "Select a config first!", Duration = 3 })
            return
        end
        pcall(function()
            if isfile("AniPixels/Configs/" .. selected .. ".json") then
                delfile("AniPixels/Configs/" .. selected .. ".json")
            end
        end)
        configDropdown:SetSelected("")
        configDropdown:SetOptions(getSavedConfigs())
        DevNgg:Notify({ Title = "Config Deleted", Content = selected .. " deleted.", Duration = 3 })
    end,
})

-- ══════════════════════════════════════════════════════════════
-- ANTI AFK — resets idle timer every 15 min so you never get kicked
-- ══════════════════════════════════════════════════════════════
local VirtualUser = game:GetService("VirtualUser")

local function doAntiAfkPing()
    pcall(function()
        VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(0.1)
        VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.Jump = true end
        end
    end)
end

local function startAntiAfk()
    if antiAfkThread then task.cancel(antiAfkThread) antiAfkThread = nil end
    antiAfkThread = task.spawn(function()
        while antiAfkEnabled do
            task.wait(15 * 60)
            if not antiAfkEnabled then break end
            doAntiAfkPing()
            DevNgg:Notify({ Title = "Anti AFK", Content = "Idle timer reset — still farming!", Duration = 3 })
        end
    end)
end

local function stopAntiAfk()
    if antiAfkThread then task.cancel(antiAfkThread) antiAfkThread = nil end
end

-- ── Anti AFK Tab ─────────────────────────────────────────────
local AntiAfkTab = Window:CreateTab("Anti AFK", nil)

AntiAfkTab:CreateSection("Anti AFK")

AntiAfkTab:CreateToggle({
    Name         = "Anti AFK (Auto)",
    CurrentValue = false,
    Flag         = "AntiAfk",
    Callback     = function(enabled)
        antiAfkEnabled = enabled
        if enabled then
            startAntiAfk()
            DevNgg:Notify({ Title = "✅ Anti AFK — ON", Content = "Idle timer resets every 15 min. Won't get kicked!", Duration = 4 })
        else
            stopAntiAfk()
            DevNgg:Notify({ Title = "Anti AFK — OFF", Content = "Stopped.", Duration = 3 })
        end
    end,
})

AntiAfkTab:CreateSection("Manual")

AntiAfkTab:CreateButton({
    Name     = "Reset Idle Timer Now",
    Callback = function()
        doAntiAfkPing()
        DevNgg:Notify({ Title = "Anti AFK", Content = "Idle timer reset manually!", Duration = 3 })
    end,
})

