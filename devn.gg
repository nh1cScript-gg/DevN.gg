-- ══════════════════════════════════════════════════════════════
-- SECTION 5: RAID BOSS DETECTION
-- Each raid boss has its OWN dedicated Campaign folder
-- with the EXACT same name as the boss:
--   Campaign["Heian Era Sukuna"].Pets.Heian Era Sukuna
--   Campaign["All For One"].Pets.All For One
--   Campaign["Madara Ten Tails"].Pets.Madara Ten Tails
--   Campaign["Boros"].Pets.Boros
--   Campaign["Fusion Zamasu (Corrupted)"].Pets.Fusion Zamasu (Corrupted)
-- ══════════════════════════════════════════════════════════════

-- The exact Campaign folder names for each raid boss
local RAID_BOSS_FOLDERS = {
    ["Heian Era Sukuna"]          = true,
    ["All For One"]               = true,
    ["Madara Ten Tails"]          = true,
    ["Boros"]                     = true,
    ["Fusion Zamasu (Corrupted)"] = true,
    ["Dio Over Heaven"]           = true,
    ["Meliodas (Demon Form 2)"]   = true,
    ["Mob"]                       = true,
    ["Aizen (Hogyoku)"]           = true,
}

-- Returns true if part lives inside a dedicated raid boss folder in Campaign
-- Campaign.BossName.Pets.Part  →  bossFolder = Campaign.BossName
local function isRaidBoss(part)
    local petsFolder = part.Parent
    local bossFolder = petsFolder and petsFolder.Parent
    if not bossFolder then return false end
    local campaignCheck = bossFolder.Parent
    if not campaignCheck or campaignCheck.Name ~= "Campaign" then return false end
    return RAID_BOSS_FOLDERS[bossFolder.Name] == true
end

-- Raid is active when any raid boss folder exists directly under Campaign
local function isRaidActive()
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return false end
    for _, child in ipairs(campaign:GetChildren()) do
        if RAID_BOSS_FOLDERS[child.Name] then return true end
    end
    return false
end

-- Find the first Part inside any raid boss folder in Campaign
local function findRaidBossPart()
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil end
    for _, child in ipairs(campaign:GetChildren()) do
        if RAID_BOSS_FOLDERS[child.Name] then
            for _, part in ipairs(child:GetDescendants()) do
                if part:IsA("Part") then
                    return part
                end
            end
        end
    end
    return nil
end

