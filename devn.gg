local function refreshHuntDropdown()
    if huntListDropdown then
        local opts = #autoHuntTargetUnits > 0 and autoHuntTargetUnits or {"(empty)"}
        huntListDropdown:SetOptions(opts)
        huntListDropdown:SetSelected("")
    end
end

