-- ── Section: Unit Scanner ─────────────────────────────────────
WishTab:CreateSection("Unit Scanner")

WishTab:CreateButton({
    Name     = "🔍 Scan ALL Units (auto copy)",
    Callback = function()
        local doodles = ReplicatedStorage:FindFirstChild("Doodles")
        if not doodles then
            DevNgg:Notify({ Title = "Error", Content = "Doodles folder not found!", Duration = 3 })
            return
        end
        local tiers = {
            ["Titan Sparking"] = {}, ["Mega Sparking"] = {},
            ["Giant Sparking"] = {}, ["Sparking"] = {}, ["Other"] = {},
        }
        local order    = {"Titan Sparking","Mega Sparking","Giant Sparking","Sparking","Other"}
        local prefixes = {"Titan Sparking ","Mega Sparking ","Giant Sparking ","Sparking "}
        for _, d in ipairs(doodles:GetChildren()) do
            local n = d.Name
            local placed = false
            for _, p in ipairs(prefixes) do
                if n:sub(1, #p) == p then
                    local tier = p:gsub("%s+$","")
                    if tiers[tier] then table.insert(tiers[tier], n) end
                    placed = true
                    break
                end
            end
            if not placed then table.insert(tiers["Other"], n) end
        end
        local lines = {}
        local total = 0
        for _, tier in ipairs(order) do
            table.sort(tiers[tier])
            if #tiers[tier] > 0 then
                table.insert(lines, "=== " .. tier:upper() .. " (" .. #tiers[tier] .. ") ===")
                for _, name in ipairs(tiers[tier]) do
                    table.insert(lines, "  " .. name)
                    total = total + 1
                end
            end
        end
        table.insert(lines, "\nTOTAL: " .. total)
        local out = table.concat(lines, "\n")
        print(out)
        local setclip = setclipboard or toclipboard or set_clipboard
        local copied = false
        if setclip then pcall(function() setclip(out) copied = true end) end
        DevNgg:Notify({
            Title   = "Scanned " .. total .. " units!",
            Content = copied and "Copied to clipboard + F9!" or "Check F9 console!",
            Duration = 5,
        })
    end,
})

