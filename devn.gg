-- ══════════════════════════════════════════════════════════════
-- SECTION 18: UI — TAB 5: ⚙️ Settings
-- ══════════════════════════════════════════════════════════════
local SettingsTab = Window:CreateTab("⚙️ Settings", nil)

SettingsTab:CreateSection("Save / Load Configs")

local currentConfigName = ""
local configDropdown    = nil

SettingsTab:CreateTextInput({
    Name        = "Config Name",
    Placeholder = "e.g. MyFarmSetup",
    Default     = "",
    Callback    = function(value) currentConfigName = value end,
})

SettingsTab:CreateButton({
    Name     = "💾 Save Config",
    Callback = function()
        if currentConfigName == "" then
            DevNgg:Notify({ Title = "⚠️ No Name", Content = "Type a config name first!", Duration = 3 })
            return
        end
        pcall(function()
            if not isfolder("AniPixels") then makefolder("AniPixels") end
            if not isfolder("AniPixels/Configs") then makefolder("AniPixels/Configs") end
            writefile("AniPixels/Configs/" .. currentConfigName .. ".json", HttpService:JSONEncode({
                AutoCollect = dragonBallAutoCollect,
                AutoHop     = dragonBallAutoHop,
                WishTarget  = wishTargetUnit,
            }))
        end)
        if configDropdown then configDropdown:SetOptions(getSavedConfigs()) end
        DevNgg:Notify({ Title = "💾 Saved!", Content = currentConfigName .. " saved!", Duration = 3 })
    end,
})

configDropdown = SettingsTab:CreateDropdown({
    Name     = "Load Config",
    Options  = getSavedConfigs(),
    Default  = "",
    Callback = function(selectedName)
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile("AniPixels/Configs/" .. selectedName .. ".json"))
        end)
        if not ok or not data then
            DevNgg:Notify({ Title = "❌ Load Failed", Content = "Could not load: " .. selectedName, Duration = 3 })
            return
        end
        dragonBallAutoCollect = false
        dragonBallAutoHop     = false
        if collectLoopThread then task.cancel(collectLoopThread) collectLoopThread = nil end
        wishTargetUnit = data.WishTarget or ""
        Window:SetToggle("AutoCollect", data.AutoCollect or false)
        Window:SetToggle("AutoHop",     data.AutoHop     or false)
        DevNgg:Notify({ Title = "✅ Config Loaded!", Content = selectedName .. " applied!", Duration = 3 })
    end,
})

SettingsTab:CreateButton({
    Name     = "🗑️ Delete Selected Config",
    Callback = function()
        local selected = configDropdown:GetSelected()
        if not selected or selected == "" then
            DevNgg:Notify({ Title = "⚠️ None Selected", Content = "Select a config first!", Duration = 3 })
            return
        end
        pcall(function()
            if isfile("AniPixels/Configs/" .. selected .. ".json") then
                delfile("AniPixels/Configs/" .. selected .. ".json")
            end
        end)
        configDropdown:SetSelected("")
        configDropdown:SetOptions(getSavedConfigs())
        DevNgg:Notify({ Title = "🗑️ Deleted", Content = selected .. " deleted.", Duration = 3 })
    end,
})

-- ══════════════════════════════════════════════════════════════
-- SECTION 19: DRAGON BALL REMOVAL LISTENER
-- ══════════════════════════════════════════════════════════════
local hopCooldownActive = false

workspace.DescendantRemoving:Connect(function(obj)
    if not dragonBallAutoHop or hopCooldownActive then return end
    if not isDragonBall(obj) then return end
    hopCooldownActive = true
    task.delay(0.5, function()
        if not dragonBallsExist() then
            DevNgg:Notify({ Title = "🐉 All Balls Gone!", Content = "Hopping to next server...", Duration = 3 })
            task.spawn(serverHop)
        end
        hopCooldownActive = false
    end)
end)

-- ══════════════════════════════════════════════════════════════
-- SECTION 20: AUTO-LOAD LAST SESSION ON START
-- ══════════════════════════════════════════════════════════════
pcall(function()
    if isfile("AniPixels/AutoFarm.json") then
        local data = HttpService:JSONDecode(readfile("AniPixels/AutoFarm.json"))
        if data then
            wishTargetUnit = data.WishTarget or ""
            Window:SetToggle("AutoCollect", data.AutoCollect or false)
            Window:SetToggle("AutoHop",     data.AutoHop     or false)
            DevNgg:Notify({ Title = "💾 Session Restored", Content = "Last settings loaded!", Duration = 3 })
        end
    end
end)
