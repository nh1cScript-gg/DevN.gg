-- ── WAIT FOR GAME TO FULLY LOAD ──────────────────────────────
-- Prevents "attempt to index nil with WaitForChild" on fast servers
if not game:IsLoaded() then game.Loaded:Wait() end

-- Wait for ReplicatedStorage.Events to exist before doing anything
local _RS = game:GetService("ReplicatedStorage")
local _ok = false
for _ = 1, 30 do  -- try for up to 15 seconds
    if _RS:FindFirstChild("Events") then
        _ok = true
        break
    end
    task.wait(0.5)
end
if not _ok then
    warn("[DevN.GG] Events folder not found after 15s — aborting.")
    return
end
task.wait(1) -- small extra buffer
-- ─────────────────────────────────────────────────────────────

