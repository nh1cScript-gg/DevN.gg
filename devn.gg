-- SECTION 15: UI — TAB 2: ✨ Shenron Wish
-- ══════════════════════════════════════════════════════════════
local WishTab = Window:CreateTab("✨ Shenron Wish", nil)

WishTab:CreateSection("Wish Configuration")

WishTab:CreateTextInput({
    Name        = "Unit to Wish For",
    Placeholder = "Exact name e.g. Titan Sparking Zoono",
    Default     = "",
    Callback    = function(text)
        wishTargetUnit = text
        DevNgg:Notify({ Title = "✨ Wish Target Set", Content = text, Duration = 2 })
        saveConfig()
    end,
})

WishTab:CreateButton({
    Name     = "🔍 List All Titan Sparking Units (F9)",
    Callback = function()
        local doodles = ReplicatedStorage:WaitForChild("Doodles")
        local found = {}
        for _, doodle in ipairs(doodles:GetChildren()) do
            if doodle.Name:find("Titan Sparking") then
                table.insert(found, doodle.Name)
            end
        end
        if #found == 0 then
            DevNgg:Notify({ Title = "❌ None Found", Content = "No Titan Sparking units in RS.Doodles.", Duration = 3 })
        else
            print("=== TITAN SPARKING UNITS (" .. #found .. ") ===")
            for _, name in ipairs(found) do print(name) end
            DevNgg:Notify({ Title = "✅ Found " .. #found .. " Units", Content = "Check console (F9)!", Duration = 5 })
        end
    end,
})

WishTab:CreateSection("Auto Wish")

WishTab:CreateToggle({
    Name         = "✨ Auto Wish on 7 Balls",
    CurrentValue = false,
    Flag         = "AutoWish",
    Callback     = function(enabled)
        if enabled and wishTargetUnit == "" then
            DevNgg:Notify({ Title = "⚠️ No Target Set!", Content = "Enter a unit name first!", Duration = 3 })
            return
        end
        dragonBallAutoWish = enabled
        DevNgg:Notify({
            Title   = enabled and "✨ Auto Wish ON" or "✨ Auto Wish OFF",
            Content = enabled and ("Wishing for: " .. wishTargetUnit) or "Disabled.",
            Duration = 3,
        })
    end,
})

WishTab:CreateButton({
    Name     = "✨ Wish Now (Manual)",
    Callback = function()
        if wishTargetUnit == "" then
            DevNgg:Notify({ Title = "⚠️ No Target!", Content = "Set a unit name first!", Duration = 3 })
            return
        end
        Events.ClaimWish:FireServer("SparkingWish", { selectedCharacter = wishTargetUnit })
        DevNgg:Notify({ Title = "✨ Wish Fired!", Content = wishTargetUnit, Duration = 3 })
    end,
})

