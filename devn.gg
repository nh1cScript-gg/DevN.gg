        if quickTeleportTarget == "" then
            DevNgg:Notify({ Title = "⚠️ No Target", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        local found = findUnitOnMap(quickTeleportTarget, quickTeleportSparking)
        if found then
            teleportToPosition(found.Position)
            DevNgg:Notify({
                Title   = "📍 Teleported!",
                Content = found.Name .. (isSparking(found.Name) and " ⚡" or ""),
                Duration = 3,
            })
        else
            DevNgg:Notify({
                Title   = "❌ Not Found",
                Content = '"' .. quickTeleportTarget .. '" not found (raid bosses excluded).',
                Duration = 3,
            })
        end
    end,
})

HuntTab:CreateButton({
    Name     = "📋 List All Units on Map (F9)",
    Callback = function()
        local campaign = workspace:FindFirstChild("Campaign")
        if not campaign then
            DevNgg:Notify({ Title = "❌ Error", Content = "Campaign folder not found!", Duration = 3 })
            return
        end
        local seen, count = {}, 0
        print("=== UNITS ON MAP (bosses excluded) ===")
        for _, part in ipairs(campaign:GetDescendants()) do
            if part:IsA("Part") and isValidUnit(part.Name) and not seen[part.Name] and not isRaidBoss(part) then
                seen[part.Name] = true
                count += 1
                print((isSparking(part.Name) and "⚡ " or "   ") .. part.Name)
            end
        end
        print("Total: " .. count)
        DevNgg:Notify({ Title = "📋 " .. count .. " Units on Map", Content = "Check console (F9)!", Duration = 4 })
    end,
})

HuntTab:CreateSection("Hunt List")

HuntTab:CreateTextInput({
    Name        = "Add Unit to Hunt List",
    Placeholder = "e.g. Zoono, Makima...",
    Default     = "",
    Callback    = function(text) autoHuntTargetUnit = text end,
})

HuntTab:CreateButton({
    Name     = "➕ Add to List",
    Callback = function()
        if autoHuntTargetUnit == "" then
            DevNgg:Notify({ Title = "⚠️ Empty!", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        -- Prevent duplicates
        for _, existing in ipairs(autoHuntTargetUnits) do
            if existing:lower() == autoHuntTargetUnit:lower() then
                DevNgg:Notify({ Title = "⚠️ Already in List", Content = autoHuntTargetUnit .. " is already added.", Duration = 3 })
                return
            end
        end
        table.insert(autoHuntTargetUnits, autoHuntTargetUnit)
        refreshHuntDropdown()
        DevNgg:Notify({
            Title   = "➕ Added: " .. autoHuntTargetUnit,
            Content = "List total: " .. #autoHuntTargetUnits .. " unit(s)",
            Duration = 3,
        })
        autoHuntTargetUnit = ""
    end,
})

-- Dropdown showing only units in hunt list — select one to remove it
huntListDropdown = HuntTab:CreateDropdown({
    Name     = "🗑️ Select Unit to Remove",
    Options  = {"(empty)"},
    Default  = "",
    Callback = function(selected)
        if selected == "(empty)" or selected == "" then return end
        for i, name in ipairs(autoHuntTargetUnits) do
            if name == selected then
                table.remove(autoHuntTargetUnits, i)
                refreshHuntDropdown()
                DevNgg:Notify({ Title = "🗑️ Removed", Content = selected .. " removed from list.", Duration = 3 })
                return
            end
        end
    end,
})

HuntTab:CreateButton({
    Name     = "🗑️ Clear Entire Hunt List",
    Callback = function()
        autoHuntTargetUnits = {}
        refreshHuntDropdown()
        DevNgg:Notify({ Title = "🗑️ Cleared", Content = "Hunt list is now empty.", Duration = 3 })
    end,
})

