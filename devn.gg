    Name    = "Choose Unit",
    Options = ALL_BARE_NAMES,
    Default = ALL_BARE_NAMES[1],
    Callback = function(selected)
        wishPickSelected = selected
    end,
})

WishTab:CreateButton({
    Name     = "➕ Add to Wish List",
    Callback = function()
        local name = wishPickSelected
        if not name or name == "" then
            DevNgg:Notify({ Title = "Nothing Selected", Content = "Pick a unit from the dropdown first.", Duration = 2 })
            return
        end
        -- Prevent duplicates (case-insensitive)
        for _, v in ipairs(wishTargets) do
            if getBareName(v):lower() == name:lower() then
                DevNgg:Notify({ Title = "Already In List", Content = "Mega Sparking " .. name .. " is already added.", Duration = 2 })
                return
            end
        end
        table.insert(wishTargets, name)
        refreshWishDropdown()
        saveWishTargets()
        DevNgg:Notify({ Title = "✅ Added", Content = "Mega Sparking " .. name, Duration = 2 })
    end,
})

