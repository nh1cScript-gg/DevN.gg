local Events = ReplicatedStorage:WaitForChild("Events")

-- ══════════════════════════════════════════════════════════════
-- SECTION 7: UNIT HELPER FUNCTIONS
-- ══════════════════════════════════════════════════════════════

-- isSparking: check unit name for sparking tier prefixes
-- NOTE: require() cannot be used from executor context, so we use name matching only
local function isSparking(unitName)
    return unitName:find("Sparking") ~= nil
end

local function isValidUnit(unitName)
    if VALID_UNITS[unitName] then return true end
    for _, prefix in ipairs(TIER_PREFIXES) do
        if unitName:sub(1, #prefix) == prefix then
            if VALID_UNITS[unitName:sub(#prefix + 1)] then return true end
        end
    end
    return false
end

-- Returns true if a part lives inside Campaign.Safari.*
-- Used to stop Campaign scans from picking up Safari units
local function isPartInSafari(part)
    local p = part.Parent
    while p and p ~= workspace do
        if p.Name == "Safari" and p.Parent and p.Parent.Name == "Campaign" then
            return true
        end
        p = p.Parent
    end
    return false
end

-- scanCampaign: used by Quick Teleport — skips raid bosses and Safari
local function scanCampaign(specificUnit, findSparking)
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil, nil end

    local specificResult = nil
    local sparkingResult = nil

    for _, part in ipairs(campaign:GetDescendants()) do
        if not part:IsA("Part") then continue end
        if not isValidUnit(part.Name) then continue end
        if isRaidBoss(part) then continue end
        if isPartInSafari(part) then continue end  -- skip Safari units

        local nameLower = part.Name:lower()

        if specificUnit and specificUnit ~= "" then
            if nameLower:find(specificUnit:lower(), 1, true) then
                specificResult = part
            end
        end

        if findSparking and isSparking(part.Name) then
            sparkingResult = sparkingResult or part
        end

        if specificResult and (not findSparking or sparkingResult) then break end
    end

    if specificResult then return specificResult, "specific" end
    if sparkingResult then return sparkingResult, "sparking" end
    return nil, nil
end

-- findUnitOnMap: used by manual Quick Teleport — skips raid bosses and Safari
local function findUnitOnMap(unitName, sparkingOnly)
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil end
    local nameLower = unitName:lower()
    for _, part in ipairs(campaign:GetDescendants()) do
        if not part:IsA("Part") then continue end
        if not part.Name:lower():find(nameLower, 1, true) then continue end
        if not isValidUnit(part.Name) then continue end
        if sparkingOnly and not isSparking(part.Name) then continue end
        if isRaidBoss(part) then continue end
        if isPartInSafari(part) then continue end  -- skip Safari units
        return part
    end
    return nil
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 8: PLAYER / CHARACTER HELPERS
-- ══════════════════════════════════════════════════════════════

local function getHumanoidRootPart()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function getWorldPosition(obj)
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then
        local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        return root and root.Position
    end
    return nil
end

local function teleportToPosition(position)
    local hrp = getHumanoidRootPart()
    if not hrp or not position then return end
    hrp.CFrame = CFrame.new(position + Vector3.new(math.random(-2, 2), 5, math.random(2, 4)))
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 9: DRAGON BALL HELPERS
-- HOW IT WORKS (confirmed from source + explorer):
--   - Balls respawn every hour and stay in workspace permanently
--   - Collection is proximity-based on the server
--   - Server fires UpdateDragonBallBackpack(count) when we collect one
--   - We ONLY trust that event — never dragonBallsExist() for hop decisions
--   - Other players' balls never fire our event so they're fully ignored
-- ══════════════════════════════════════════════════════════════

local lastKnownCount = 0
local lastCountTime  = 0

-- Simple scan — no cache needed, balls are always in workspace
local function getAllDragonBalls()
    local balls = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart")
            and obj.Name:match("^DragonBall%d$")
            and obj.Transparency < 0.9 then
            table.insert(balls, obj)
        end
    end
    return balls
end

local function dragonBallsExist()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart")
            and obj.Name:match("^DragonBall%d$")
            and obj.Transparency < 0.9 then
            return true
        end
    end
    return false
end

-- Teleport on top — server registers proximity and increments our count
-- Balls never disappear, so we just teleport and move on
local function collectDragonBall(ball)
    if not ball or not ball.Parent then return end
    local hrp = getHumanoidRootPart()
    if not hrp then return end
    hrp.CFrame = CFrame.new(ball.Position + Vector3.new(0, 3, 0))
    task.wait(0.3)
end

local function collectAllDragonBalls()
    local balls = getAllDragonBalls()
    if #balls == 0 then
        DevNgg:Notify({ Title = "No Dragon Balls Found", Content = "No Dragon Balls on this server.", Duration = 3 })
        if dragonBallAutoHop then task.spawn(serverHop) end
        return false
    end
    isCollecting = true
    -- Up to 3 passes to catch any missed balls
    for pass = 1, 3 do
        if lastKnownCount >= 7 then break end
        local current = getAllDragonBalls()
        for _, ball in ipairs(current) do
            if not dragonBallAutoCollect then break end
            if lastKnownCount >= 7 then break end
            collectDragonBall(ball)
        end
        if lastKnownCount >= 7 then break end
        task.wait(0.5)
    end
    isCollecting = false
    return true
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 10: SERVER HOP
-- ══════════════════════════════════════════════════════════════

local function fetchServerPage(placeId, cursor)
    local order = math.random(1, 2) == 1 and "Asc" or "Desc"
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=" .. order .. "&limit=100"
    if cursor then url = url .. "&cursor=" .. cursor end
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if success and result and result.data then
        return result.data, result.nextPageCursor
    end
    return nil, nil
end

local function shuffleTable(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
    return t
end

function serverHop(noCheck)
    if isHopping then return end

    if not noCheck then
        for _ = 1, 2 do
            if dragonBallsExist() then
                DevNgg:Notify({ Title = "Dragon Balls Found!", Content = "Dragon Balls detected — cancelling server hop.", Duration = 3 })
                if dragonBallAutoCollect then task.spawn(collectAllDragonBalls) end
                return
            end
            task.wait(0.5)
        end
    end

    isHopping    = true
    isCollecting = false
    DevNgg:Notify({ Title = "Server Hop", Content = "Looking for a valid server...", Duration = 2 })

    local placeId      = game.PlaceId
    local currentJobId = game.JobId
    local teleported   = false

    local function tryTeleport(serverId)
        if teleported then return end
        teleported = true
        DevNgg:Notify({ Title = "Hopping", Content = "Jumping to new server.", Duration = 2 })
        TeleportService:TeleportToPlaceInstance(placeId, serverId, LocalPlayer)
    end

    local function isServerValid(server)
        return server.id ~= currentJobId and server.playing < server.maxPlayers
    end

    local firstPageData, nextCursor = fetchServerPage(placeId, nil)
    if not firstPageData then
        DevNgg:Notify({ Title = "Hop Failed", Content = "Retrying in 5s...", Duration = 3 })
        isHopping = false
        task.wait(5)
        serverHop(noCheck)
        return
    end

    local shuffled = shuffleTable({table.unpack(firstPageData)})
    for _, server in ipairs(shuffled) do
        if isServerValid(server) then
            tryTeleport(server.id)
            isHopping = false
            return
        end
    end

    if not nextCursor then
        DevNgg:Notify({ Title = "No Server Found", Content = "Retrying in 10s...", Duration = 4 })
        isHopping = false
        task.wait(10)
        serverHop(noCheck)
        return
    end

    local activeTasks, allTasksDone = 0, false

    local function fetchAndChain(cursor)
        if teleported then return end
        activeTasks += 1
        task.spawn(function()
            local data, newCursor = fetchServerPage(placeId, cursor)
            if data and not teleported then
                local shuffledData = shuffleTable({table.unpack(data)})
                for _, server in ipairs(shuffledData) do
                    if isServerValid(server) then tryTeleport(server.id) break end
                end
                if newCursor and not teleported then fetchAndChain(newCursor) end
            end
            activeTasks -= 1
            if activeTasks == 0 then allTasksDone = true end
        end)
    end

    fetchAndChain(nextCursor)

    local elapsed = 0
    while not teleported and not allTasksDone and elapsed < 15 do
        task.wait(0.03)
        elapsed += 0.03
    end

    if not teleported then
        DevNgg:Notify({ Title = "No Server Found", Content = "Retrying in 10s...", Duration = 4 })
        task.wait(10)
        isHopping = false
        serverHop(noCheck)
    end

    isHopping = false
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 11: AUTO HUNT LOOP
-- Continuously scans all units in list
-- After finding: stops and resets toggle
-- After hop: waits for map to load then scans again
-- ══════════════════════════════════════════════════════════════

local function checkCampaignList()
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil, nil end

    -- Check each unit name independently — Campaign only, never Safari
    for _, unitName in ipairs(autoCampaignTargetUnits) do
        local target = unitName:lower()
        for _, part in ipairs(campaign:GetDescendants()) do
            if not part:IsA("Part") then continue end
            if not isValidUnit(part.Name) then continue end
            if isRaidBoss(part) then continue end
            if isPartInSafari(part) then continue end  -- skip Safari units
            if part.Name:lower():find(target, 1, true) then
                return part, "specific"
            end
        end
    end

    -- Check for any sparking unit — Campaign only, never Safari
    if autoCampaignFindSparking then
        for _, part in ipairs(campaign:GetDescendants()) do
            if not part:IsA("Part") then continue end
            if not isValidUnit(part.Name) then continue end
            if isRaidBoss(part) then continue end
            if isPartInSafari(part) then continue end  -- skip Safari units
            if isSparking(part.Name) then
                return part, "sparking"
            end
        end
    end

    return nil, nil
end

local function startAutoCampaignLoop()
    if autoCampaignThread then task.cancel(autoCampaignThread) autoCampaignThread = nil end
    autoCampaignThread = task.spawn(function()
        task.wait(2) -- wait for map to load after server hop
        while autoCampaignEnabled do
            local foundUnit, foundReason = checkCampaignList()

            if foundUnit then
                -- Retry teleport until HRP exists and we actually land near the unit
                local landed = false
                for attempt = 1, 5 do
                    local hrp = getHumanoidRootPart()
                    if hrp and foundUnit and foundUnit.Parent then
                        teleportToPosition(foundUnit.Position)
                        task.wait(0.4)
                        -- Verify we actually got close (within 30 studs)
                        local hrp2 = getHumanoidRootPart()
                        if hrp2 and foundUnit.Parent and (hrp2.Position - foundUnit.Position).Magnitude < 30 then
                            landed = true
                            break
                        end
                    else
                        task.wait(0.5) -- wait for character to load
                    end
                end
                DevNgg:Notify({
                    Title   = foundReason == "sparking" and "Sparking: " .. foundUnit.Name or "Found: " .. foundUnit.Name,
                    Content = landed and "Teleported!" or "Found but teleport may have failed — check your position.",
                    Duration = 5,
                })
                autoCampaignEnabled = false
                pcall(function() Window:SetToggle("AutoCampaignEnabled", false) end)
                return

            elseif autoCampaignServerHop then
                DevNgg:Notify({
                    Title   = "Not Found",
                    Content = "Checked " .. #autoCampaignTargetUnits .. " unit(s) — hopping...",
                    Duration = 3,
                })
                serverHop(true)
                -- Wait for server hop + map load, then rescan
                task.wait(12)

            else
                -- No hop: keep rescanning current server every 2s
                task.wait(2)
            end

            task.wait(0.3)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 12: AUTO WISH
-- CONFIRMED: ClaimWish:FireServer() works directly — unit goes
-- straight to inventory. Auto loop fires it every 5 seconds.
-- ══════════════════════════════════════════════════════════════

-- Strips any tier prefix and returns the bare character name
local function getBareName(name)
    return name
        :gsub("^Titan Sparking ","")
        :gsub("^Mega Sparking ","")
        :gsub("^Giant Sparking ","")
        :gsub("^Sparking ","")
        :match("^%s*(.-)%s*$")
end

-- Returns bare + full name of the best wish target
local function getBestWishTarget()
    if #wishTargets == 0 then return nil, nil end
    local doodles = ReplicatedStorage:FindFirstChild("Doodles")
    for _, entry in ipairs(wishTargets) do
        local bare = getBareName(entry)
        local full = "Mega Sparking " .. bare
        if doodles and doodles:FindFirstChild(full) then
            return bare, full
        end
    end
    local bare = getBareName(wishTargets[1])
    return bare, "Mega Sparking " .. bare
end

-- Fires ClaimWish directly — confirmed working
local function fireClaimWish()
    local bareName, fullName = getBestWishTarget()
    if not bareName then
        DevNgg:Notify({ Title = "No Targets", Content = "Add a unit in the Shenron tab first!", Duration = 4 })
        return false
    end
    pcall(function()
        Events.ClaimWish:FireServer("SparkingWish", { selectedCharacter = fullName })
    end)
    DevNgg:Notify({ Title = "Wish Sent!", Content = fullName, Duration = 3 })
    return true
end

-- Auto loop: fires ClaimWish every 5 seconds while enabled
local function startWishLoop()
    if wishLoopThread then task.cancel(wishLoopThread) wishLoopThread = nil end
    wishLoopThread = task.spawn(function()
        while dragonBallAutoWish do
            fireClaimWish()
            for _ = 1, 50 do
                if not dragonBallAutoWish then break end
                task.wait(0.1)
            end
        end
    end)
end

local function stopWishLoop()
    if wishLoopThread then task.cancel(wishLoopThread) wishLoopThread = nil end
end
-- SECTION 13: AUTO MERGE
-- ══════════════════════════════════════════════════════════════

-- Finds the best matching unit entry in DoodleInv for a given name input.
-- Tries: exact match → ends-with match → contains match (all case-insensitive)
local function findMergeUnit(doodleInv, targetName)
    if targetName == "" then
        -- no target — find any unit with 4+ copies
        for _, entry in ipairs(doodleInv:GetChildren()) do
            if entry:IsA("IntValue") and entry.Value >= 4 then
                return entry
            end
        end
        return nil
    end

    local lower = targetName:lower()

    -- Pass 1: exact match (case-insensitive)
    for _, entry in ipairs(doodleInv:GetChildren()) do
        if entry.Name:lower() == lower then return entry end
    end
    -- Pass 2: entry name ends with the typed name  e.g. "Sparking Toji" ends with "toji"
    for _, entry in ipairs(doodleInv:GetChildren()) do
        local eName = entry.Name:lower()
        if eName:sub(-#lower) == lower then return entry end
    end
    -- Pass 3: entry name contains the typed name anywhere
    for _, entry in ipairs(doodleInv:GetChildren()) do
        if entry.Name:lower():find(lower, 1, true) then return entry end
    end
    return nil
end

local function performMerge()
    local doodleInv = LocalPlayer:FindFirstChild("DoodleInv")
    if not doodleInv then
        DevNgg:Notify({ Title = "Merge Failed", Content = "DoodleInv not found!", Duration = 3 })
        return
    end

    -- Find the Crushinator — search workspace broadly in case Map structure differs
    local crushinator = nil
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Crushinator" then crushinator = obj break end
    end
    if not crushinator then
        DevNgg:Notify({ Title = "Merge Failed", Content = "Crushinator not found in workspace!", Duration = 3 })
        return
    end

    local mergePrompt = crushinator:FindFirstChildOfClass("ProximityPrompt", true)
    if not mergePrompt then
        -- Try searching Activate child
        local activate = crushinator:FindFirstChild("Activate")
        if activate then mergePrompt = activate:FindFirstChildOfClass("ProximityPrompt") end
    end
    if not mergePrompt then
        DevNgg:Notify({ Title = "Merge Failed", Content = "Merge ProximityPrompt not found!", Duration = 3 })
        return
    end

    -- Find the unit to merge using fuzzy matching
    local unitEntry = findMergeUnit(doodleInv, mergeTargetUnit)

    if not unitEntry then
        if mergeTargetUnit ~= "" then
            DevNgg:Notify({
                Title   = "Unit Not Found",
                Content = "Could not find '" .. mergeTargetUnit .. "' in your inventory.",
                Duration = 4,
            })
        else
            DevNgg:Notify({ Title = "Nothing to Merge", Content = "No unit with 4+ copies found.", Duration = 3 })
        end
        return
    end

    if unitEntry.Value < 4 then
        DevNgg:Notify({
            Title   = "Not Enough Copies",
            Content = unitEntry.Name .. " — Have: " .. unitEntry.Value .. "/4",
            Duration = 3,
        })
        return
    end

    local unitToMerge = unitEntry.Name
    local slotMapping = { ["1"] = unitToMerge, ["2"] = unitToMerge, ["3"] = unitToMerge, ["4"] = unitToMerge }
    Events.SquadUpdate:FireServer(slotMapping)
    task.wait(0.5)
    fireproximityprompt(mergePrompt)
    DevNgg:Notify({ Title = "Merging!", Content = "Merging 4x " .. unitToMerge, Duration = 3 })
    task.wait(4)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 14: AUTO RAID
-- ══════════════════════════════════════════════════════════════

-- Click the Auto battle button — search all GUI descendants
local function clickAutoBattle()
    for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if obj.Name == "Auto" and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
            pcall(function() obj.MouseButton1Click:Fire() end)
            pcall(function() obj:activate() end)
            return true
        end
    end
    return false
end

-- Teleport directly ON TOP of the boss part (not offset by 5,5)
-- Then retry clicking Auto battle up to 8 times with short waits
local function teleportToBossAndFight()
    local boss = findRaidBossPart()
    if not boss then
        DevNgg:Notify({ Title = "Boss Not Found", Content = "No raid boss found in Campaign!", Duration = 3 })
        return false
    end

    local hrp = getHumanoidRootPart()
    if hrp then
        -- Teleport right on top of the boss part
        hrp.CFrame = CFrame.new(boss.Position + Vector3.new(0, 3, 0))
    end

    DevNgg:Notify({
        Title   = "⚔ Raid Boss!",
        Content = "Teleported to " .. boss.Name .. " — starting battle...",
        Duration = 3,
    })

    -- Retry clicking Auto battle — GUI may take a moment to appear
    local clicked = false
    for attempt = 1, 8 do
        task.wait(0.5)
        if clickAutoBattle() then
            clicked = true
            DevNgg:Notify({ Title = "⚔ Auto Battle ON", Content = "Auto battle enabled! (attempt " .. attempt .. ")", Duration = 3 })
            break
        end
        -- Re-teleport closer each retry in case we drifted
        if hrp and boss.Parent then
            hrp.CFrame = CFrame.new(boss.Position + Vector3.new(0, 3, 0))
        end
    end

    if not clicked then
        DevNgg:Notify({ Title = "⚠ Auto Battle", Content = "Could not click Auto — enable it manually.", Duration = 4 })
    end

    return true
end

local function startRaidLoop()
    raidLoopThread = task.spawn(function()
        local wasActive = false
        while autoRaidEnabled do
            local active = isRaidActive()
            if active and not wasActive then
                task.wait(1.5) -- wait for boss to fully load
                if autoRaidEnabled then
                    teleportToBossAndFight()
                end
                wasActive = true
            elseif not active and wasActive then
                wasActive = false
                DevNgg:Notify({ Title = "Raid Ended", Content = "Boss defeated!", Duration = 3 })
            end
            task.wait(1)
        end
    end)
end

-- Also catch boss folders spawning via DescendantAdded
workspace.DescendantAdded:Connect(function(obj)
    if not autoRaidEnabled then return end
    if not (obj:IsA("Model") or obj:IsA("Folder")) then return end
    local n = obj.Name
    if n:find("Wild") or n:find("OddFight") or n:find("Safari")
    or n:find("Fusion Zamasu") or n:find("Heian") then
        local parent = obj.Parent
        if parent and parent.Name == "Campaign" then
            task.wait(2) -- wait for parts to load
            if autoRaidEnabled then
                teleportToBossAndFight()
            end
        end
    end
end)

-- ══════════════════════════════════════════════════════════════
-- SECTION 14B: AUTO SAFARI
-- Scans Campaign.Safari.*.Pets for target unit
-- Teleports to that Safari NPC's HumanoidRootPart
-- Server hops if not found
-- ══════════════════════════════════════════════════════════════

local function findSafariWithUnit(unitName, findSparking)
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil, nil end
    local target = unitName and unitName:lower() or ""
    local sparkingResult, sparkingHrp = nil, nil
    for _, safari in ipairs(campaign:GetChildren()) do
        if safari.Name == "Safari" then
            local pets = safari:FindFirstChild("Pets")
            if pets then
                local hrp = safari:FindFirstChild("HumanoidRootPart")
                for _, pet in ipairs(pets:GetChildren()) do
                    -- Check specific target first
                    if target ~= "" and pet.Name:lower():find(target, 1, true) then
                        if hrp then return hrp, pet.Name, "specific" end
                    end
                    -- Check sparking
                    if findSparking and isSparking(pet.Name) and not sparkingResult then
                        sparkingResult = pet.Name
                        sparkingHrp    = hrp
                    end
                end
            end
        end
    end
    -- Return sparking if no specific found
    if sparkingHrp then return sparkingHrp, sparkingResult, "sparking" end
    return nil, nil, nil
end

local function startSafariLoop()
    if safariThread then task.cancel(safariThread) safariThread = nil end
    safariThread = task.spawn(function()
        task.wait(2)
        while autoSafariEnabled do
            if safariTargetUnit == "" and not autoSafariSparking then
                DevNgg:Notify({ Title = "No Target", Content = "Set a unit or enable sparking detection!", Duration = 3 })
                autoSafariEnabled = false
                pcall(function() Window:SetToggle("AutoSafari", false) end)
                return
            end

            local hrp, foundName, foundReason = findSafariWithUnit(safariTargetUnit, autoSafariSparking)

            if hrp then
                local myHrp = getHumanoidRootPart()
                if myHrp then
                    myHrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 5, 3))
                end
                DevNgg:Notify({
                    Title   = foundReason == "sparking" and "Safari Sparking: " .. foundName or "Found: " .. foundName,
                    Content = foundReason == "sparking" and "Sparking unit in Safari!" or "Target found! Battle starting...",
                    Duration = 4,
                })

                -- Wait for battle to start (max 8s)
                local waited = 0
                local battleStarted = false
                local conn
                conn = Events.ShowBattle.OnClientEvent:Connect(function(_, name)
                    if name == LocalPlayer.Name then
                        battleStarted = true
                        if conn then conn:Disconnect() conn = nil end
                    end
                end)
                while not battleStarted and waited < 8 do
                    task.wait(0.3)
                    waited += 0.3
                    if hrp and hrp.Parent then
                        myHrp = getHumanoidRootPart()
                        if myHrp then
                            myHrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 5, 3))
                        end
                    end
                end
                if conn then conn:Disconnect() conn = nil end

                -- Wait for battle result (max 60s)
                if battleStarted then
                    local done = false
                    local resultConn
                    resultConn = Events.BattleResult.OnClientEvent:Connect(function(name, result)
                        if name == LocalPlayer.Name then
                            done = true
                            if resultConn then resultConn:Disconnect() resultConn = nil end
                            DevNgg:Notify({
                                Title   = result == "Won" and "Safari: Won" or "Safari: Lost",
                                Content = foundName .. " battle finished!",
                                Duration = 3,
                            })
                        end
                    end)
                    local elapsed = 0
                    while not done and elapsed < 60 do
                        task.wait(0.5)
                        elapsed += 0.5
                    end
                    if resultConn then resultConn:Disconnect() resultConn = nil end
                end
                task.wait(1)

            elseif autoSafariServerHop then
                DevNgg:Notify({
                    Title   = "Safari: Not Found",
                    Content = "Nothing found — hopping...",
                    Duration = 3,
                })
                serverHop(true)
                task.wait(12)
            else
                task.wait(3)
            end
        end
    end)
end
-- Dragon Ball: event-driven + lightweight 3s fallback poll
-- ══════════════════════════════════════════════════════════════

-- UpdateDragonBallBackpack fires when OUR count changes.
-- This is the ONLY signal we trust — workspace balls are permanent
-- (they respawn every hour) so dragonBallsExist() is always true
-- and cannot be used to decide whether to hop.
-- UpdateDragonBallBackpack is the ONLY trigger we trust.
-- Balls are permanent (respawn hourly) so dragonBallsExist() is
-- always true and useless — we use lastCountTime instead.
Events.UpdateDragonBallBackpack.OnClientEvent:Connect(function(count)
    if count ~= lastKnownCount then
        lastKnownCount = count
        lastCountTime  = tick()
    end
    if not dragonBallAutoCollect or isCollecting or isHopping then return end
    if count >= 7 then return end
    task.spawn(collectAllDragonBalls)
end)

local function startCollectLoop()
    if collectLoopThread then task.cancel(collectLoopThread) collectLoopThread = nil end
    collectLoopThread = task.spawn(function()
        task.wait(1.5)
        -- Collect any balls already on map on first start
        if not isCollecting and not isHopping and lastKnownCount < 7 then
            task.spawn(collectAllDragonBalls)
        end
        while dragonBallAutoCollect do
            task.wait(5)
            if not dragonBallAutoCollect then break end
            if isCollecting or isHopping then continue end
            if lastKnownCount >= 7 then continue end
            local timeSince = tick() - lastCountTime
            if timeSince < 30 then
                -- Count changed recently — keep collecting
                task.spawn(collectAllDragonBalls)
            elseif dragonBallAutoHop then
                -- No new ball in 30s — nothing left for us here
                DevNgg:Notify({ Title = "No New Dragon Balls", Content = "Hopping to next server...", Duration = 2 })
                serverHop()
                task.wait(8)
            end
        end
    end)
end

local function startMergeLoop()
    mergeLoopThread = task.spawn(function()
        while autoMergeEnabled do
            performMerge()
            task.wait(1)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 16: CONFIG SAVE / LOAD
-- ══════════════════════════════════════════════════════════════

local function saveConfig()
    pcall(function()
        if not isfolder("AniPixels") then makefolder("AniPixels") end
        writefile("AniPixels/AutoFarm.json", HttpService:JSONEncode({
            AutoCollect = dragonBallAutoCollect,
            AutoHop     = dragonBallAutoHop,
            WishTargets = wishTargets,
        }))
    end)
end

local function getSavedConfigs()
    local list = {}
    pcall(function()
        if isfolder("AniPixels/Configs") then
            for _, filePath in ipairs(listfiles("AniPixels/Configs")) do
                local name = filePath:match("([^/\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
    end)
    return list
end

