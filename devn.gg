    Name     = "🗑 Remove Selected",
    Callback = function()
        local sel = wishListDD:GetSelected()
        if sel == "" or sel == "(empty)" then
            DevNgg:Notify({ Title = "Nothing Selected", Content = "Pick a name from the list first.", Duration = 2 })
            return
        end
        for i, v in ipairs(wishTargets) do
            if getBareName(v) == sel or v == sel then
                table.remove(wishTargets, i)
                break
            end
        end
        refreshWishDropdown()
        saveWishTargets()
        DevNgg:Notify({ Title = "🗑 Removed", Content = sel, Duration = 2 })
    end,
})

