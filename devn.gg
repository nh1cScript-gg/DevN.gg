-- SECTION 16: UI — TAB 3: 🎯 Hunt
-- ══════════════════════════════════════════════════════════════
local HuntTab = Window:CreateTab("🎯 Hunt", nil)

-- ── Quick Teleport ───────────────────────────────────────────
HuntTab:CreateSection("Quick Teleport (Manual, One-Time)")

HuntTab:CreateTextInput({
    Name        = "Unit Name",
    Placeholder = "e.g. Zoono, Makima, Hakari... (partial ok)",
    Default     = "",
    Callback    = function(text)
        if text ~= "" then
            quickTeleportTarget = text
            DevNgg:Notify({ Title = "📍 Target Set", Content = text, Duration = 2 })
        end
    end,
})

HuntTab:CreateToggle({
    Name         = "⚡ Sparking Only (Quick Teleport)",
    CurrentValue = false,
    Flag         = "QuickSparkingOnly",
    Callback     = function(enabled)
        quickTeleportSparking = enabled
        DevNgg:Notify({
            Title   = enabled and "⚡ Sparking Only ON" or "⚡ Sparking Only OFF",
            Content = enabled and "Only teleports to Sparking+ units." or "All tiers allowed.",
            Duration = 3,
        })
    end,
})

HuntTab:CreateButton({
    Name     = "📍 Teleport Now",
    Callback = function()
        if quickTeleportTarget == "" then
            DevNgg:Notify({ Title = "⚠️ No Target", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        local found = findUnitOnMap(quickTeleportTarget, quickTeleportSparking)
        if found then
            teleportToPosition(found.Position)
            DevNgg:Notify({
                Title   = "📍 Teleported!",
                Content = found.Name .. (isSparking(found.Name) and " ⚡" or ""),
                Duration = 3,
            })
        else
            DevNgg:Notify({ Title = "❌ Not Found", Content = '"' .. quickTeleportTarget .. '" not on this map.', Duration = 3 })
        end
    end,
})

HuntTab:CreateButton({
    Name     = "📋 List All Units on Map (F9)",
    Callback = function()
        local campaign = workspace:FindFirstChild("Campaign")
        if not campaign then
            DevNgg:Notify({ Title = "❌ Error", Content = "Campaign folder not found!", Duration = 3 })
            return
        end
        local seen, count = {}, 0
        print("=== UNITS CURRENTLY ON MAP ===")
        for _, part in ipairs(campaign:GetDescendants()) do
            if part:IsA("Part") and isValidUnit(part.Name) and not seen[part.Name] then
                seen[part.Name] = true
                count += 1
                print((isSparking(part.Name) and "⚡ " or "   ") .. part.Name)
            end
        end
        print("Total: " .. count .. " units")
        DevNgg:Notify({ Title = "📋 " .. count .. " Units on Map", Content = "Check console (F9)!", Duration = 4 })
    end,
})

-- ── Auto Hunt + Server Hop ───────────────────────────────────
HuntTab:CreateSection("Auto Hunt + Server Hop (Unit List)")

HuntTab:CreateTextInput({
    Name        = "Add Unit to Hunt List",
    Placeholder = "e.g. Zoono, Makima... (one at a time)",
    Default     = "",
    Callback    = function(text)
        autoHuntTargetUnit = text
    end,
})

HuntTab:CreateButton({
    Name     = "➕ Add Unit to List",
    Callback = function()
        if autoHuntTargetUnit == "" then
            DevNgg:Notify({ Title = "⚠️ Empty!", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        table.insert(autoHuntTargetUnits, autoHuntTargetUnit)
        DevNgg:Notify({
            Title   = "➕ Added: " .. autoHuntTargetUnit,
            Content = "List total: " .. #autoHuntTargetUnits .. " unit(s)",
            Duration = 3,
        })
        autoHuntTargetUnit = ""
    end,
})

HuntTab:CreateButton({
    Name     = "📋 Show Hunt List (F9)",
    Callback = function()
        if #autoHuntTargetUnits == 0 then
            DevNgg:Notify({ Title = "📋 Hunt List", Content = "Empty! Add units above.", Duration = 3 })
            return
        end
        print("=== HUNT LIST (" .. #autoHuntTargetUnits .. ") ===")
        for i, name in ipairs(autoHuntTargetUnits) do
            print(i .. ". " .. name)
        end
        DevNgg:Notify({
            Title   = "📋 Hunt List (" .. #autoHuntTargetUnits .. ")",
            Content = "Check console (F9)!",
            Duration = 3,
        })
    end,
})

HuntTab:CreateButton({
    Name     = "🗑️ Clear Hunt List",
    Callback = function()
        autoHuntTargetUnits = {}
        DevNgg:Notify({ Title = "🗑️ Cleared", Content = "Hunt list is now empty.", Duration = 3 })
    end,
})

HuntTab:CreateToggle({
    Name         = "⚡ Also Stop on Any Sparking Unit",
    CurrentValue = true,
    Flag         = "HuntFindSparking",
    Callback     = function(enabled)
        autoHuntFindSparking = enabled
        DevNgg:Notify({
            Title   = enabled and "⚡ Sparking Detection ON" or "⚡ Sparking Detection OFF",
            Content = enabled and "Will stop on any sparking unit." or "Only stopping on list units.",
            Duration = 3,
        })
    end,
})

HuntTab:CreateToggle({
    Name         = "🔁 Start Auto Hunt + Server Hop",
    CurrentValue = false,
    Flag         = "AutoHuntEnabled",
    Callback     = function(enabled)
        autoHuntEnabled = enabled
        if enabled then
            if #autoHuntTargetUnits == 0 and not autoHuntFindSparking then
                DevNgg:Notify({
                    Title   = "⚠️ Nothing to Hunt!",
                    Content = "Add units to the list or enable sparking detection.",
                    Duration = 3,
                })
                autoHuntEnabled = false
                return
            end
            DevNgg:Notify({
                Title   = "🔁 Auto Hunt Started!",
                Content = #autoHuntTargetUnits .. " unit(s) in list"
                    .. (autoHuntFindSparking and " + Any Sparking" or ""),
                Duration = 4,
            })
            startAutoHuntLoop()
        else
            DevNgg:Notify({ Title = "🔁 Auto Hunt Stopped", Content = "Hunt loop cancelled.", Duration = 3 })
            if autoHuntThread then task.cancel(autoHuntThread) autoHuntThread = nil end
        end
    end,
})

