-- Wish  (Mega Sparking only — list of targets, picks first found)
local wishTargets    = {}   -- list of bare character names e.g. {"Zoono","Gojo"}
local wishListDropdown = nil  -- UI ref, assigned after tab is built

-- Auto-save wish targets to a dedicated file instantly when list changes
local WISH_FILE = "AniPixels/WishTargets.json"
local function saveWishTargets()
    pcall(function()
        if not isfolder("AniPixels") then makefolder("AniPixels") end
        writefile(WISH_FILE, HttpService:JSONEncode({ targets = wishTargets }))
    end)
end
local function loadWishTargets()
    pcall(function()
        if isfile and isfile(WISH_FILE) then
            local data = HttpService:JSONDecode(readfile(WISH_FILE))
            if data and type(data.targets) == "table" then
                wishTargets = data.targets
            end
        end
    end)
end

local function refreshWishDropdown()
    if wishListDropdown then
        local opts = #wishTargets > 0 and wishTargets or {"(empty)"}
        wishListDropdown:SetOptions(opts)
        wishListDropdown:SetSelected("")
    end
end

