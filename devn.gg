            Content = enabled and "Will hop servers until unit is found." or "Will only check current server.",
            Duration = 3,
        })
    end,
})

HuntTab:CreateToggle({
    Name         = "🔁 Start Auto Hunt",
    CurrentValue = false,
    Flag         = "AutoHuntEnabled",
    Callback     = function(enabled)
        autoHuntEnabled = enabled
        if enabled then
            if #autoHuntTargetUnits == 0 and not autoHuntFindSparking then
                DevNgg:Notify({ Title = "⚠️ Nothing to Hunt!", Content = "Add units or enable sparking detection.", Duration = 3 })
                autoHuntEnabled = false
                return
            end
            DevNgg:Notify({
                Title   = "🔁 Auto Hunt Started!",
                Content = #autoHuntTargetUnits .. " unit(s)" .. (autoHuntFindSparking and " + Sparking" or "") .. (autoHuntServerHop and " | Hop ON" or " | Hop OFF"),
                Duration = 4,
            })
            startAutoHuntLoop()
        else
            DevNgg:Notify({ Title = "🔁 Auto Hunt Stopped", Content = "Hunt loop cancelled.", Duration = 3 })
            if autoHuntThread then task.cancel(autoHuntThread) autoHuntThread = nil end
        end
    end,
})

