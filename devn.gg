})

CampaignTab:CreateButton({
    Name     = "List All Units on Map",
    Callback = function()
        local campaign = workspace:FindFirstChild("Campaign")
        if not campaign then
            DevNgg:Notify({ Title = "Error", Content = "Campaign folder not found!", Duration = 3 })
            return
        end
        local seen, count = {}, 0
        print("=== UNITS ON MAP (bosses excluded) ===")
        for _, part in ipairs(campaign:GetDescendants()) do
            if part:IsA("Part") and isValidUnit(part.Name) and not seen[part.Name] and not isRaidBoss(part) then
                seen[part.Name] = true
                count += 1
                print((isSparking(part.Name) and "" or " ") .. part.Name)
            end
        end
        print("Total: " .. count)
        DevNgg:Notify({ Title = " " .. count .. " Units on Map", Content = "Check console (F9)!", Duration = 4 })
    end,
})

CampaignTab:CreateSection("Unit List")

CampaignTab:CreateTextInput({
    Name        = "Add Unit to Campaign List",
    Placeholder = "e.g. Zoono, Makima...",
    Default     = "",
    Callback    = function(text) autoCampaignTargetUnit = text end,
})

CampaignTab:CreateButton({
    Name     = "Add to List",
    Callback = function()
        if autoCampaignTargetUnit == "" then
            DevNgg:Notify({ Title = "Empty Input", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        for _, existing in ipairs(autoCampaignTargetUnits) do
            if existing:lower() == autoCampaignTargetUnit:lower() then
                DevNgg:Notify({ Title = "Already in List", Content = autoCampaignTargetUnit .. " is already added.", Duration = 3 })
                return
            end
        end
        table.insert(autoCampaignTargetUnits, autoCampaignTargetUnit)
        refreshCampaignDropdown()
        DevNgg:Notify({
            Title   = " Added: " .. autoCampaignTargetUnit,
            Content = "List total: " .. #autoCampaignTargetUnits .. " unit(s)",
            Duration = 3,
        })
        autoCampaignTargetUnit = ""
    end,
})

campaignListDropdown = CampaignTab:CreateDropdown({
    Name     = "Remove Unit",
    Options  = {"(empty)"},
    Default  = "",
    Callback = function(selected)
        if selected == "(empty)" or selected == "" then return end
        for i, name in ipairs(autoCampaignTargetUnits) do
            if name == selected then
                table.remove(autoCampaignTargetUnits, i)
                refreshCampaignDropdown()
                DevNgg:Notify({ Title = "Unit Removed", Content = selected .. " removed from list.", Duration = 3 })
                return
            end
        end
    end,
})

CampaignTab:CreateButton({
    Name     = "Clear List",
    Callback = function()
        autoCampaignTargetUnits = {}
        refreshCampaignDropdown()
        DevNgg:Notify({ Title = "List Cleared", Content = "Campaign list is now empty.", Duration = 3 })
    end,
})

CampaignTab:CreateSection("Automation")

CampaignTab:CreateToggle({
    Name         = "Auto Campaign",
    CurrentValue = false,
    Flag         = "AutoCampaignEnabled",
    Callback     = function(enabled)
        autoCampaignEnabled = enabled
        if enabled then
            if #autoCampaignTargetUnits == 0 then
                DevNgg:Notify({ Title = "Nothing to Find", Content = "Add units to the list first.", Duration = 3 })
                autoCampaignEnabled = false
                return
            end
            DevNgg:Notify({
                Title   = "Auto Campaign — Running",
                Content = #autoCampaignTargetUnits .. " unit(s) in list",
                Duration = 4,
            })
            startAutoCampaignLoop()
        else
            DevNgg:Notify({ Title = "Auto Campaign — Stopped", Content = "Campaign loop cancelled.", Duration = 3 })
            if autoCampaignThread then task.cancel(autoCampaignThread) autoCampaignThread = nil end
        end
    end,
})

