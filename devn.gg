    Callback = function()
        if quickTeleportTarget == "" then
            DevNgg:Notify({ Title = "No Target", Content = "Type a unit name first!", Duration = 3 })
            return
        end
        local found = findUnitOnMap(quickTeleportTarget, quickTeleportSparking)
        if found then
            teleportToPosition(found.Position)
            DevNgg:Notify({
                Title   = " Teleported!",
                Content = found.Name .. (isSparking(found.Name) and "" or ""),
                Duration = 3,
            })
        else
