-- SECTION 24: AUTO-LOAD LAST SELECTED CONFIG ON STARTUP
-- Only runs if a config was previously selected manually
-- ══════════════════════════════════════════════════════════════
task.wait(1) -- wait for UI to fully initialize

-- Always load wish targets from dedicated file first (survives server hops)
loadWishTargets()
refreshWishDropdown()
if #wishTargets > 0 then
    DevNgg:Notify({
        Title   = "Wish Targets Restored!",
        Content = #wishTargets .. " unit(s) loaded. Auto Wish ready.",
        Duration = 4,
    })
end

-- Load saved ELO data
loadPvpElo()
if pvpWins + pvpLosses > 0 then
    DevNgg:Notify({
        Title   = "PvP ELO Restored: " .. pvpElo,
        Content = "Wins: " .. pvpWins .. " | Losses: " .. pvpLosses,
        Duration = 4,
    })
end

-- ══════════════════════════════════════════════════════════════
-- AUTO BATTLE CHAT ACCEPT (runs permanently)
-- When a player accepts our RequestBattle, we get a BattleChat
-- popup with a "Battle" button. Auto-click it immediately.
-- From decompiled source: Battle() fires RequestBattle:FireServer(Char.Value)
-- ══════════════════════════════════════════════════════════════
task.spawn(function()
    local ScreenGui = LocalPlayer.PlayerGui:WaitForChild("ScreenGui", 10)
    if not ScreenGui then return end
    local BattleChats = ScreenGui:WaitForChild("BattleChats", 10)
    if not BattleChats then return end
    local BattleChat = BattleChats:WaitForChild("BattleChat", 10)
    if not BattleChat then return end

    -- Watch for BattleChat becoming visible = someone accepted our request
    BattleChat:GetPropertyChangedSignal("Visible"):Connect(function()
        if not BattleChat.Visible then return end
        if not autoPvpEnabled then return end
        task.wait(0.05) -- tiny delay so Char.Value is set
        -- Auto-fire the battle exactly as the Battle() function does
        pcall(function()
            Events.RequestBattle:FireServer(BattleChat.Char.Value)
        end)
        BattleChat.Visible = false
    end)
end)

-- ══════════════════════════════════════════════════════════════
-- AUTO ACCEPT INCOMING BATTLE REQUESTS (for alt account)
-- When another player sends us a RequestBattle, auto-accept it
-- Decompiled source: Battle button fires RequestBattle:FireServer(arg1.Character)
-- ══════════════════════════════════════════════════════════════
Events.RequestBattle.OnClientEvent:Connect(function(requester)
    if not autoAcceptBattles then return end
    if not requester then return end
    local char = requester.Character
    if not char then return end
    task.wait(0.1)
    pcall(function()
        Events.RequestBattle:FireServer(char)
    end)
end)

pcall(function()
    if not isfile("AniPixels/LastConfig.json") then return end
    local meta = HttpService:JSONDecode(readfile("AniPixels/LastConfig.json"))
    if not meta or not meta.lastConfig then return end
    local configName = meta.lastConfig
    if not isfile("AniPixels/Configs/" .. configName .. ".json") then return end
    local data = HttpService:JSONDecode(readfile("AniPixels/Configs/" .. configName .. ".json"))
    if not data then return end

    -- Apply all settings silently
    wishTargets             = (type(data.WishTargets) == "table") and data.WishTargets or {}
    refreshWishDropdown()
    safariTargetUnit        = data.SafariTarget or ""
    autoSafariServerHop     = data.SafariHop ~= false
    autoSafariSparking      = data.SafariSparking ~= false
    if type(data.CampaignUnits) == "table" then
        autoCampaignTargetUnits = data.CampaignUnits
    end
    autoCampaignFindSparking = data.CampaignSparking ~= false
    autoCampaignServerHop    = data.CampaignHop ~= false
    mergeTargetUnit          = data.MergeTarget or ""

    -- Apply toggles (triggers callbacks which start loops)
    pcall(function() Window:SetToggle("AutoCollect", data.AutoCollect or false) end)
    pcall(function() Window:SetToggle("AutoHop",     data.AutoHop     or false) end)
    pcall(function() Window:SetToggle("AutoWish",    data.AutoWish    or false) end)
    pcall(function() Window:SetToggle("AutoSafari",  data.AutoSafari  or false) end)
    pcall(function() Window:SetToggle("AutoCampaignEnabled", data.AutoCampaign or false) end)

    refreshCampaignDropdown()
    if configDropdown then pcall(function() configDropdown:SetSelected(configName) end) end

    DevNgg:Notify({
        Title   = "Auto-Loaded: " .. configName,
        Content = "Settings restored. All features running.",
        Duration = 4,
    })
end)

