-- Tier prefixes used in unit names
local TIER_PREFIXES = {
    "Titan Sparking ", "Mega Sparking ", "Giant Sparking ", "Sparking ",
    "Titan ", "Mega ", "Giant ",
}

-- ══════════════════════════════════════════════════════════════
-- SECTION 5: UNIT HELPER FUNCTIONS
-- ══════════════════════════════════════════════════════════════

-- Returns true if the unit name contains "Sparking"
local function isSparking(unitName)
    return unitName:find("Sparking") ~= nil
end

-- Returns true if unit exists in VALID_UNITS (strips tier prefix first)
local function isValidUnit(unitName)
    if VALID_UNITS[unitName] then return true end
    for _, prefix in ipairs(TIER_PREFIXES) do
        if unitName:sub(1, #prefix) == prefix then
            if VALID_UNITS[unitName:sub(#prefix + 1)] then return true end
        end
    end
    return false
end

-- Scans workspace.Campaign for a specific unit and/or any sparking unit
-- specificUnit: partial name to match, "" = skip specific search
-- findSparking: if true, also returns first sparking unit found
-- Returns: (unitPart, reason) where reason = "specific" | "sparking" | nil
local function scanCampaign(specificUnit, findSparking)
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil, nil end

    local specificResult = nil
    local sparkingResult = nil

    for _, part in ipairs(campaign:GetDescendants()) do
        if not part:IsA("Part") then continue end
        if not isValidUnit(part.Name) then continue end

        local nameLower = part.Name:lower()

        -- Check specific unit match
        if specificUnit and specificUnit ~= "" then
            if nameLower:find(specificUnit:lower(), 1, true) then
                specificResult = part
            end
        end

        -- Check for any sparking unit
        if findSparking and isSparking(part.Name) then
            sparkingResult = sparkingResult or part
        end

        if specificResult and (not findSparking or sparkingResult) then break end
    end

    if specificResult then return specificResult, "specific" end
    if sparkingResult then return sparkingResult, "sparking" end
    return nil, nil
end

-- Simple single-unit finder for manual quick teleport
local function findUnitOnMap(unitName, sparkingOnly)
    local campaign = workspace:FindFirstChild("Campaign")
    if not campaign then return nil end
    local nameLower = unitName:lower()
    for _, part in ipairs(campaign:GetDescendants()) do
        if not part:IsA("Part") then continue end
        if not part.Name:lower():find(nameLower, 1, true) then continue end
        if not isValidUnit(part.Name) then continue end
        if sparkingOnly and not isSparking(part.Name) then continue end
        return part
    end
    return nil
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 6: PLAYER / CHARACTER HELPERS
-- ══════════════════════════════════════════════════════════════

local function getHumanoidRootPart()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

local function getWorldPosition(obj)
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then
        local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        return root and root.Position
    end
    return nil
end

local function teleportToPosition(position)
    local hrp = getHumanoidRootPart()
    if not hrp or not position then return end
    hrp.CFrame = CFrame.new(position + Vector3.new(math.random(-2, 2), 5, math.random(2, 4)))
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 7: DRAGON BALL HELPERS
-- ══════════════════════════════════════════════════════════════

local function isDragonBall(obj)
    if not obj:IsA("BasePart") then return false end
    if obj.Parent and obj.Parent:FindFirstChildOfClass("Humanoid") then return false end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and obj:IsDescendantOf(plr.Character) then return false end
    end
    local n = obj.Name:lower()
    return n == "dragonball" or n == "dragon_ball" or n == "dball"
        or n:match("^dragonball%d$") or n:match("^dragon_ball%d$")
        or n == "dragon ball"        or n:match("^dragon ball %d$")
end

local function getAllDragonBalls()
    local balls = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isDragonBall(obj) then table.insert(balls, obj) end
    end
    return balls
end

local function dragonBallsExist()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isDragonBall(obj) then return true end
    end
    return false
end

local function collectDragonBall(ball)
    local hrp = getHumanoidRootPart()
    local pos = getWorldPosition(ball)
    if not hrp or not pos then return end
    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 2, 0))
    task.wait(0.05)
    local prompt = ball:FindFirstChildOfClass("ProximityPrompt")
                or ball.Parent:FindFirstChildOfClass("ProximityPrompt")
    if prompt then fireproximityprompt(prompt) end
end

local function collectAllDragonBalls()
    local balls = getAllDragonBalls()
    if #balls == 0 then
        DevNgg:Notify({ Title = "🐉 Dragon Ball", Content = "No Dragon Balls found.", Duration = 3 })
        if dragonBallAutoHop then task.spawn(serverHop) end
        return false
    end
    local finished, total = 0, #balls
    for _, ball in ipairs(balls) do
        task.spawn(function()
            collectDragonBall(ball)
            finished += 1
        end)
    end
    while finished < total do task.wait(0.03) end
    DevNgg:Notify({ Title = "🐉 Collected!", Content = total .. " Dragon Ball(s) collected!", Duration = 4 })
    return true
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 8: SERVER HOP
-- ══════════════════════════════════════════════════════════════

local function fetchServerPage(placeId, cursor)
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    if cursor then url = url .. "&cursor=" .. cursor end
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if success and result and result.data then
        return result.data, result.nextPageCursor
    end
    return nil, nil
end

function serverHop(noCheck)
    if isHopping then return end

    if not noCheck then
        for _ = 1, 2 do
            if dragonBallsExist() then
                DevNgg:Notify({ Title = "🐉 Balls Found!", Content = "Cancelling hop.", Duration = 3 })
                if dragonBallAutoCollect then task.spawn(collectAllDragonBalls) end
                return
            end
            task.wait(0.5)
        end
    end

    isHopping   = true
    isCollecting = false
    DevNgg:Notify({ Title = "🔀 Server Hop", Content = "Searching for a server...", Duration = 2 })

    local placeId      = game.PlaceId
    local currentJobId = game.JobId
    local teleported   = false

    local function tryTeleport(serverId)
        if teleported then return end
        teleported = true
        DevNgg:Notify({ Title = "🔀 Hopping!", Content = "Teleporting to new server!", Duration = 2 })
        TeleportService:TeleportToPlaceInstance(placeId, serverId, LocalPlayer)
    end

    local function isServerValid(server)
        return server.id ~= currentJobId and server.playing < server.maxPlayers
    end

    local firstPageData, nextCursor = fetchServerPage(placeId, nil)
    if not firstPageData then
        DevNgg:Notify({ Title = "❌ Hop Failed", Content = "Retrying in 5s...", Duration = 3 })
        isHopping = false
        task.wait(5)
        serverHop(noCheck)
        return
    end

    for _, server in ipairs(firstPageData) do
        if isServerValid(server) then
            tryTeleport(server.id)
            isHopping = false
            return
        end
    end

    if not nextCursor then
        DevNgg:Notify({ Title = "❌ No Server Found", Content = "Retrying in 10s...", Duration = 4 })
        isHopping = false
        task.wait(10)
        serverHop(noCheck)
        return
    end

    local activeTasks, allTasksDone = 0, false

    local function fetchAndChain(cursor)
        if teleported then return end
        activeTasks += 1
        task.spawn(function()
            local data, newCursor = fetchServerPage(placeId, cursor)
            if data and not teleported then
                for _, server in ipairs(data) do
                    if isServerValid(server) then tryTeleport(server.id) break end
                end
                if newCursor and not teleported then fetchAndChain(newCursor) end
            end
            activeTasks -= 1
            if activeTasks == 0 then allTasksDone = true end
        end)
    end

    fetchAndChain(nextCursor)

    local elapsed = 0
    while not teleported and not allTasksDone and elapsed < 15 do
        task.wait(0.03)
        elapsed += 0.03
    end

    if not teleported then
        DevNgg:Notify({ Title = "❌ No Server Found", Content = "Retrying in 10s...", Duration = 4 })
        task.wait(10)
        isHopping = false
        serverHop(noCheck)
    end

    isHopping = false
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 9: AUTO HUNT LOOP
-- Loops through the hunt list, hops servers until one is found
-- ══════════════════════════════════════════════════════════════
local function startAutoHuntLoop()
    autoHuntThread = task.spawn(function()
        task.wait(3) -- wait for map to load on new server

        while autoHuntEnabled do
            local foundUnit   = nil
            local foundReason = nil

            -- Check each unit in the hunt list one by one
            for _, unitName in ipairs(autoHuntTargetUnits) do
                local result, reason = scanCampaign(unitName, false)
                if result then
                    foundUnit   = result
                    foundReason = "specific"
                    break
                end
            end

            -- If no specific unit found, check for any sparking unit
            if not foundUnit and autoHuntFindSparking then
                local result, reason = scanCampaign("", true)
                if result then
                    foundUnit   = result
                    foundReason = "sparking"
                end
            end

            if foundUnit then
                -- Found! Teleport and stop the loop
                teleportToPosition(foundUnit.Position)

                if foundReason == "specific" then
                    DevNgg:Notify({
                        Title   = "✅ Found: " .. foundUnit.Name,
                        Content = "Unit from your list!" .. (isSparking(foundUnit.Name) and " ⚡" or ""),
                        Duration = 5,
                    })
                elseif foundReason == "sparking" then
                    DevNgg:Notify({
                        Title   = "⚡ Sparking Found: " .. foundUnit.Name,
                        Content = "Sparking unit on this server!",
                        Duration = 5,
                    })
                end

                autoHuntEnabled = false
                return

            else
                -- Nothing found on this server, hop to the next
                DevNgg:Notify({
                    Title   = "❌ Nothing Found",
                    Content = "Hopping to next server...",
                    Duration = 3,
                })
                serverHop(true)
                task.wait(6) -- wait for new server map to fully load
            end

            task.wait(1)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 10: AUTO WISH (SHENRON)
-- ══════════════════════════════════════════════════════════════
local Events = ReplicatedStorage:WaitForChild("Events")

Events.UpdateDragonBallBackpack.OnClientEvent:Connect(function(count)
    if not dragonBallAutoWish then return end
    if count >= 7 and not isCollecting then
        isCollecting = true
        task.wait(0.2)
        Events.SummonShenron:FireServer()
        DevNgg:Notify({ Title = "🐉 Summoning Shenron!", Content = "All 7 balls collected!", Duration = 3 })
    end
end)

Events.ShenronWishes.OnClientEvent:Connect(function()
    if not dragonBallAutoWish then return end
    if wishTargetUnit == "" then
        DevNgg:Notify({ Title = "⚠️ No Wish Target", Content = "Set a unit in the Shenron tab!", Duration = 3 })
        isCollecting = false
        return
    end
    task.wait(0.2)
    Events.ClaimWish:FireServer("SparkingWish", { selectedCharacter = wishTargetUnit })
    DevNgg:Notify({ Title = "✨ Wish Granted!", Content = "Wished for: " .. wishTargetUnit, Duration = 3 })
    isCollecting = false
    task.wait(0.5)
    if dragonBallAutoHop then task.spawn(serverHop) end
end)

-- ══════════════════════════════════════════════════════════════
-- SECTION 11: AUTO MERGE
-- ══════════════════════════════════════════════════════════════
local function performMerge()
    local doodleInv = LocalPlayer:FindFirstChild("DoodleInv")
    if not doodleInv then return end

    local crushinator = workspace:FindFirstChild("Map")
        and workspace.Map:FindFirstChild("Lab")
        and workspace.Map.Lab:FindFirstChild("Crushinator")
    if not crushinator then
        DevNgg:Notify({ Title = "❌ Merge Failed", Content = "Crushinator not found!", Duration = 3 })
        return
    end

    local mergePrompt = crushinator:FindFirstChild("Activate")
        and crushinator.Activate:FindFirstChildOfClass("ProximityPrompt")
    if not mergePrompt then
        DevNgg:Notify({ Title = "❌ Merge Failed", Content = "Merge prompt not found!", Duration = 3 })
        return
    end

    local unitToMerge = nil

    if mergeTargetUnit ~= "" then
        local unitEntry = doodleInv:FindFirstChild(mergeTargetUnit)
        if unitEntry and unitEntry.Value >= 4 then
            unitToMerge = mergeTargetUnit
        else
            DevNgg:Notify({
                Title   = "⚠️ Not Enough Copies",
                Content = mergeTargetUnit .. " — Have: " .. (unitEntry and unitEntry.Value or 0) .. "/4",
                Duration = 3,
            })
            return
        end
    else
        for _, entry in ipairs(doodleInv:GetChildren()) do
            if entry.Value >= 4 then
                unitToMerge = entry.Name
                break
            end
        end
        if not unitToMerge then
            DevNgg:Notify({ Title = "⚠️ Nothing to Merge", Content = "No unit with 4+ copies found.", Duration = 3 })
            return
        end
    end

    local slotMapping = { ["1"] = unitToMerge, ["2"] = unitToMerge, ["3"] = unitToMerge, ["4"] = unitToMerge }
    Events.SquadUpdate:FireServer(slotMapping)
    task.wait(0.5)
    fireproximityprompt(mergePrompt)
    DevNgg:Notify({ Title = "⚗️ Merging!", Content = "Merging 4x " .. unitToMerge, Duration = 3 })
    task.wait(4)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 12: MAIN BACKGROUND LOOPS
-- ══════════════════════════════════════════════════════════════

local function startCollectLoop()
    collectLoopThread = task.spawn(function()
        task.wait(3)
        while dragonBallAutoCollect do
            if not isCollecting and not isHopping then
                if #getAllDragonBalls() > 0 then
                    collectAllDragonBalls()
                else
                    DevNgg:Notify({ Title = "❌ No Balls Found", Content = "Hopping server...", Duration = 2 })
                    if dragonBallAutoHop then serverHop() end
                end
            end
            task.wait(1)
        end
    end)
end

local function startMergeLoop()
    mergeLoopThread = task.spawn(function()
        while autoMergeEnabled do
            performMerge()
            task.wait(1)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 13: CONFIG SAVE / LOAD
-- ══════════════════════════════════════════════════════════════

local function saveConfig()
    pcall(function()
        if not isfolder("AniPixels") then makefolder("AniPixels") end
        writefile("AniPixels/AutoFarm.json", HttpService:JSONEncode({
            AutoCollect = dragonBallAutoCollect,
            AutoHop     = dragonBallAutoHop,
            WishTarget  = wishTargetUnit,
        }))
    end)
end

local function getSavedConfigs()
    local list = {}
    pcall(function()
        if isfolder("AniPixels/Configs") then
            for _, filePath in ipairs(listfiles("AniPixels/Configs")) do
                local name = filePath:match("([^/\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
    end)
    return list
end

